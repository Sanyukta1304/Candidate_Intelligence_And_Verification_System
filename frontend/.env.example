# CredVerify Frontend - Environment Configuration
# Copy this file to .env and update values as needed

# Backend API URL
# Default for development: http://localhost:5000
# Production: https://api.credverify.com
API_URL=http://localhost:5000

# Optional: Frontend URL (for error tracking, etc.)
# VITE_APP_URL=http://localhost:3000

# Optional: Analytics or monitoring keys
# VITE_GA_ID=your-google-analytics-id
# VITE_SENTRY_DSN=your-sentry-dsn

